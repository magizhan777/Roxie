# Roxie Embedded Studio Configuration

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Frontend
FRONTEND_URL=http://localhost:3000
FRONTEND_BUILD_DIR=./dist

# Arduino CLI
ARDUINO_CLI_PATH=/path/to/arduino-cli
ARDUINO_SKETCH_PATH=./builds/arduino

# ESP-IDF
EPSDIR=/path/to/esp-idf
ESP_BUILD_PATH=./builds/esp32

# LLM Configuration (for AI firmware generation)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4
LLM_API_KEY=your_api_key_here
LLM_TIMEOUT=30000

# Hardware Database
HARDWARE_DB_PATH=./config/boards
COMPONENTS_DB_PATH=./config/components

# Serial Communication
SERIAL_BAUD_RATE=115200
SERIAL_TIMEOUT=5000

# Build Configuration
BUILD_TIMEOUT=120000
UPLOAD_TIMEOUT=60000
COMPILER_VERBOSE=false

# Cache
CACHE_ENABLED=true
CACHE_TTL=3600

# Logging
LOG_FILE=./logs/app.log
DEBUG_MODE=false
